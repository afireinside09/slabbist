# Supabase (service role - write access)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Grading APIs (fill in as credentials are obtained)
PSA_API_KEY=
# PSA pop-report SpecIDs — comma-separated integers found in the PSA pop-report URL path,
# e.g. https://www.psacard.com/pop/tcg-cards/123456 → PSA_POP_SPEC_IDS=123456
# Multiple IDs supported: PSA_POP_SPEC_IDS=123456,789012
PSA_POP_SPEC_IDS=
BECKETT_OPG_KEY=
TAG_API_KEY=

# eBay (Browse + Marketplace Insights)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_MARKETPLACE_INSIGHTS_APPROVED=false

# Runtime knobs
LOG_LEVEL=info
HTTP_USER_AGENT=slabbist-tcgcsv/0.1 (+https://slabbist.com)
