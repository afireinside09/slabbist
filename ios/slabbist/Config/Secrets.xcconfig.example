// Slabbist iOS — Supabase build-time secrets.
//
// Copy this file to `Secrets.xcconfig` and fill in the values from the
// repo-root `.envrc`. `Secrets.xcconfig` is .gitignored — never commit
// real credentials.
//
// Wiring it in (once the UI refresh finishes with project.pbxproj):
//   1. In Xcode: Project → Info → Configurations →
//      set Debug / Release to `Secrets.xcconfig` (or base it via
//      `#include "Secrets.xcconfig"` from an existing `.xcconfig`).
//   2. In Info.plist add string keys:
//        SUPABASE_URL              $(SUPABASE_URL)
//        SUPABASE_PUBLISHABLE_KEY  $(SUPABASE_PUBLISHABLE_KEY)
//      `AppEnvironment` reads both Info.plist and process env, so
//      either path works; Info.plist is the reliable route for
//      archive / TestFlight / App Store builds which don't inherit a
//      shell env.
//
// Local development: launching Xcode via `open ios/slabbist/slabbist.xcodeproj`
// from a direnv-enabled shell already exports these variables, so
// `Secrets.xcconfig` is only required for CI / archive builds.
//
// NOTE: xcconfig swallows `//` as a comment inside values. If any
// Supabase key ever contains `//`, escape it as `/$()/` or move to
// Info.plist-only injection.

SUPABASE_URL              = https:/$()/your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY  = sb_publishable_REPLACE_ME
